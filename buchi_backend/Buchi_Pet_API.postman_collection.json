{
  "info": {
    "_postman_id": "buchi-pet-api-v1",
    "name": "Buchi Pet Adoption API",
    "description": "Production-ready FastAPI backend for Buchi Pet Adoption platform.\n\nBase URL: http://localhost:8000\n\n**Features:**\n- Multi-select pet search filters\n- Local DB + Petfinder API fallback\n- Combined adopt flow (name + phone + pet_id)\n- Report generation\n- AI-style pet matching",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Pets",
      "item": [
        {
          "name": "Create Pet (with photos)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "type", "value": "Dog", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "size", "value": "small", "type": "text" },
                { "key": "age", "value": "baby", "type": "text" },
                { "key": "good_with_children", "value": "true", "type": "text" },
                { "key": "Photo", "type": "file", "src": [] }
              ]
            },
            "url": { "raw": "{{base_url}}/create_pet", "host": ["{{base_url}}"], "path": ["create_pet"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"pet_id\": \"7278942789482\"\n}"
            }
          ]
        },
        {
          "name": "Get Pets (single filter)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/get_pets?type=Dog&size=small&age=baby&good_with_children=true&limit=5",
              "host": ["{{base_url}}"],
              "path": ["get_pets"],
              "query": [
                { "key": "type", "value": "Dog" },
                { "key": "size", "value": "small" },
                { "key": "age", "value": "baby" },
                { "key": "good_with_children", "value": "true" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"pets\": [\n    {\n      \"pet_id\": \"1\",\n      \"source\": \"local\",\n      \"type\": \"Dog\",\n      \"gender\": \"male\",\n      \"size\": \"small\",\n      \"age\": \"baby\",\n      \"good_with_children\": true,\n      \"Photos\": [\"http://localhost:8000/uploads/1_abc.jpg\"]\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Pets (multi-select type + age)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/get_pets?type=Dog&type=Cat&age=baby&age=young&limit=10",
              "host": ["{{base_url}}"],
              "path": ["get_pets"],
              "query": [
                { "key": "type", "value": "Dog" },
                { "key": "type", "value": "Cat" },
                { "key": "age", "value": "baby" },
                { "key": "age", "value": "young" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Pets (multi-select size + gender)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/get_pets?size=small&size=medium&size=large&gender=male&gender=female&limit=10",
              "host": ["{{base_url}}"],
              "path": ["get_pets"],
              "query": [
                { "key": "size", "value": "small" },
                { "key": "size", "value": "medium" },
                { "key": "size", "value": "large" },
                { "key": "gender", "value": "male" },
                { "key": "gender", "value": "female" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Pet Detail",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/get_pets/1",
              "host": ["{{base_url}}"],
              "path": ["get_pets", "1"]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"pet_id\": \"1\",\n  \"source\": \"local\",\n  \"type\": \"Dog\",\n  \"gender\": \"male\",\n  \"size\": \"small\",\n  \"age\": \"baby\",\n  \"good_with_children\": true,\n  \"Photos\": [],\n  \"breed\": null,\n  \"created_at\": \"2024-01-01T00:00:00\"\n}"
            }
          ]
        },
        {
          "name": "Upload Dog Image",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] },
                { "key": "sub_id", "value": "demo_user", "type": "text" }
              ]
            },
            "url": { "raw": "{{base_url}}/upload_dog_image", "host": ["{{base_url}}"], "path": ["upload_dog_image"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Image uploaded successfully\",\n  \"data\": {\n    \"id\": \"FjQPVSf8Ef\",\n    \"status\": \"labelled\",\n    \"upload_timestamp\": \"2026-04-09T12:13:49.078Z\",\n    \"links\": {\n      \"self\": \"/images/FjQPVSf8Ef\",\n      \"status\": \"/images/FjQPVSf8Ef/status\"\n    }\n  }\n}"
            }
          ]
        },
        {
          "name": "List Uploaded Images",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/list_uploaded_images?sub_id=demo_user&limit=5",
              "host": ["{{base_url}}"],
              "path": ["list_uploaded_images"],
              "query": [
                { "key": "sub_id", "value": "demo_user" },
                { "key": "limit", "value": "5" }
              ]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"images\": [\n    {\n      \"id\": \"FjQPVSf8Ef\",\n      \"url\": \"https://cdn4.thedogapi.com/optimized/FjQPVSf8Ef.jpg\",\n      \"width\": 348,\n      \"height\": 500,\n      \"breeds\": [],\n      \"categories\": []\n    }\n  ]\n}"
            }
          ]
        },
        {
          "name": "Get Image Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/get_image/FjQPVSf8Ef",
              "host": ["{{base_url}}"],
              "path": ["get_image", "FjQPVSf8Ef"]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": \"FjQPVSf8Ef\",\n  \"url\": \"https://storage.googleapis.com/dog-api-uploads-prod/originals/2588af1d-d670-4629-9760-ab4bd97c3860.jpeg\",\n  \"width\": 348,\n  \"height\": 500,\n  \"breeds\": [\n    {\n      \"id\": \"2\",\n      \"name\": \"Afghan Hound\",\n      \"species_id\": \"2\",\n      \"life_span\": \"12-15\",\n      \"temperament\": \"Independent, dignified, aloof, loyal, confident\",\n      \"origin\": \"Afghanistan\",\n      \"country_code\": \"AF\",\n      \"description\": \"Ancient, elegant sighthound with dramatic, flowing silky coat and aristocratic bearing, bred for hunting large prey in mountainous terrain\",\n      \"bred_for\": null,\n      \"perfect_for\": null,\n      \"breed_group\": \"Hound\",\n      \"history\": \"Ancient sighthound originating in the mountainous regions of Afghanistan, where they were prized for hunting large prey like gazelles and leopards. Valued for their speed, stamina, and problem-solving intelligence over rugged terrain. Introduced to the Western world by British officers in the early 20th century.\",\n      \"alt_names\": null,\n      \"wikipedia_url\": \"https://en.wikipedia.org/wiki/Afghan_Hound\",\n      \"reference_image_id\": \"atummvxJRT\"\n    }\n  ],\n  \"categories\": []\n}"
            }
          ]
        },
        {
          "name": "Delete Image",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/delete_image/FjQPVSf8Ef",
              "host": ["{{base_url}}"],
              "path": ["delete_image", "FjQPVSf8Ef"]
            }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Image deleted successfully\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Add Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abebe Kebede\",\n  \"phone\": \"0922222222\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/add_customer", "host": ["{{base_url}}"], "path": ["add_customer"] }
          },
          "response": [
            {
              "name": "Success (new customer)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"customer_id\": \"7278942789482\"\n}"
            },
            {
              "name": "Success (existing phone - returns same ID)",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"customer_id\": \"7278942789482\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Adoption",
      "item": [
        {
          "name": "Adopt (by IDs)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customer_id\": \"1\",\n  \"pet_id\": \"1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/adopt", "host": ["{{base_url}}"], "path": ["adopt"] }
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"success\",\n  \"adoption_id\": \"7278942789482\"\n}"
            },
            {
              "name": "Customer Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"detail\": \"Customer 999 not found\"\n}"
            }
          ]
        },
        {
          "name": "Adopt Now (name + phone + pet — Combined Flow)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tigist Alemu\",\n  \"phone\": \"0911234567\",\n  \"pet_id\": \"1\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/adopt_now", "host": ["{{base_url}}"], "path": ["adopt_now"] }
